---
import Layout from '../layouts/Layout.astro';

const experience = [
	{
		period: '2023 — Present',
		company: 'PT. Smart IT Mantap Digital Indonesia',
		role: 'Fullstack Web & Mobile Developer',
		copy: 'Shipping mobile and web products across HR, field operations, distribution, logistics, tailoring commerce, and wellness.',
		points: [
			'Built and maintained 6 React Native Android apps, 3 Next.js PWAs, and contributed to 3 Laravel ERP systems.',
			'Delivered end-to-end HR workflows including geolocation and face-biometric attendance, leave, reimbursement, loans, approvals, and analytics.',
			'Turned Figma systems into responsive interfaces while improving API integration, state management, rendering, and release quality.',
		],
	},
	{
		period: '2021 — 2023',
		company: 'PT. Kreator Solusi Informasi',
		role: 'Software Engineer / Fullstack Web Developer',
		copy: 'Connected web, mobile, backend, and data workflows for property sales and construction operations.',
		points: [
			'Developed NVKen CRM with CodeIgniter 3, React, jQuery, REST APIs, and Microsoft SQL Server.',
			'Built 2 native Android apps in Java for construction monitoring and sales activity.',
			'Handled query optimization, testing, deployment support, debugging, and technical documentation.',
		],
	},
	{
		period: '2017 — 2018',
		company: 'Daun Palm Food & Beverages',
		role: 'Web Developer · Internship',
		copy: 'Designed and built a CodeIgniter cafe management system with an integrated mobile-web POS and operational reporting.',
		points: [],
	},
	{
		period: '2015 — 2017',
		company: 'ITATS Programming Language Laboratory',
		role: 'Laboratory Assistant',
		copy: 'Mentored C++ and Java students, authored practical modules, and supported the lab’s development environment.',
		points: [],
	},
];

const skills = [
	['Frontend', 'React.js · Next.js · JavaScript · HTML · CSS · Tailwind CSS', 'window'],
	['Mobile', 'React Native · Android Java · Geolocation · Biometrics · WebView', 'phone'],
	['Backend', 'PHP · Laravel · CodeIgniter · Express.js · REST APIs', 'server'],
	['Data & delivery', 'SQL Server · MySQL · Git · Testing · Debugging · Deployment', 'database'],
];

const portfolio = [
	{
		category: 'React Native',
		projects: [
			['Kinerja', 'Cloud HR app for biometric attendance, loans, reimbursements, leave, approvals, and workforce analytics.', [['Google Play', 'https://play.google.com/store/apps/details?id=app.kinerja.employee']]],
			['Kinerja Admin', 'Mobile HR operations app for reviewing employee requests and managing approvals away from the desk.', [['Google Play', 'https://play.google.com/store/apps/details?id=app.kinerja.employer']]],
			['Bie Hin Circlo', 'Premium tailoring experience translated from Figma into an intuitive app for measurements, appointments, orders, rewards, and payments.', [], 'Pending submission'],
			['Lintas 7 Benua', 'FMCG dealer app that makes product discovery and customer inquiries easier for an international trading company.', [['Google Play', 'https://play.google.com/store/apps/details?id=com.l7be.dealer']]],
			['Samando Dealers', 'Dealer app for browsing engines, spare parts, and agricultural or marine equipment from a trusted distributor.', [['Google Play', 'https://play.google.com/store/apps/details?id=id.samando.dealers']]],
			['Lookman Dajaja Driver', 'Two expedition driver apps supporting intercity and local deliveries through trip monitoring, travel records, and operational tasks.', [['Intercity app', 'https://play.google.com/store/apps/details?id=net.lookmandjaja.driver.luar_kota'], ['Local delivery app', 'https://play.google.com/store/apps/details?id=net.lookmandjaja.driver.driver_dalam_kota']]],
		],
	},
	{
		category: 'Progressive Web Apps',
		projects: [
			['Anda Wellness', 'Responsive booking PWA that turns a polished Figma design into an easy path to spa and home-call treatments.', [['Visit website', 'https://my.andawellness.co.id/home']]],
			['Cek Mantap', 'Inspection tool for building checklists, running standard operating procedure audits, and producing reports.'],
			['Fieldmate', 'Installable field-team app for attendance, schedules, customer visits, orders, custom forms, and stock checks.', [['Visit website', 'https://web.fieldmate.id/']]],
		],
	},
	{
		category: 'Native Android',
		projects: [
			['NVBuilt', 'Construction monitoring app for tracking property development work and progress in the field.'],
			['NVCRM', 'Sales app for recording prospective buyers and supporting property marketing workflows.'],
		],
	},
	{
		category: 'Business Systems',
		projects: [
			['Ken CRM', 'Property developer CRM that organizes customer, sales, and operational processes in one system.'],
			['Bintang Plasma', 'ERP platform for the day-to-day operations of an electronics distributor.'],
			['Wahana Pest Control', 'Service operations system for coordinating customer work and internal delivery processes.'],
			['Radz Exinterior', 'ERP system designed around the operational needs of a contractor business.'],
		],
	},
];

const socialLinks = [
	['LinkedIn', 'https://www.linkedin.com/in/indrawanfaisal/'],
	['Instagram', 'https://www.instagram.com/isalindrawan/'],
	['Threads', 'https://www.threads.com/@isalindrawan'],
	['Facebook', 'https://www.facebook.com/isalindrawan76'],
	['GitHub', 'https://github.com/isalindrawan'],
];
---

<Layout>
	<div class="ambient ambient-one" data-parallax="-0.08"></div>
	<div class="ambient ambient-two" data-parallax="0.05"></div>
	<div class="ambient ambient-three" data-parallax="-0.13"></div>
	<div class="cursor-glow" aria-hidden="true"></div>

	<header class="nav-shell">
		<nav aria-label="Primary navigation">
			<a class="brand" href="#home" aria-label="Faisal Indrawan, home">FI<span>.</span></a>
			<div class="nav-links">
				<a href="#about">About</a>
				<a href="#experience">Experience</a>
				<a href="#skills">Skills</a>
				<a href="#portfolio">Portfolio</a>
				<a href="#contact">Contact</a>
			</div>
			<button class="theme-toggle" type="button" aria-label="Switch color theme">
				<svg class="sun" viewBox="0 0 24 24" aria-hidden="true"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.93 4.93l1.42 1.42M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.42-1.42M17.66 6.34l1.41-1.41"/></svg>
				<svg class="moon" viewBox="0 0 24 24" aria-hidden="true"><path d="M20.5 14.3A8.5 8.5 0 0 1 9.7 3.5 8.5 8.5 0 1 0 20.5 14.3Z"/></svg>
			</button>
		</nav>
	</header>

	<main>
		<section id="home" class="hero">
			<div class="hero-copy">
				<div class="system-line"><span>Portfolio system</span><span>2026 / Online</span></div>
				<p class="eyebrow">Fullstack Web & Mobile Developer · Surabaya</p>
				<h1>I build software that makes work feel <em>simpler.</em></h1>
				<p class="intro">
					I’m Faisal, a fullstack developer with 5+ years of experience turning complex
					business workflows into reliable, human-friendly web and mobile products.
				</p>
				<div class="hero-actions">
					<a class="button" href="#experience">Explore my work <span>↘</span></a>
					<a class="text-link" href="mailto:isalindrawan@outlook.com">Let’s talk</a>
				</div>
				<div class="proof" aria-label="Career highlights">
					<div><strong>6</strong><span>React Native apps</span></div>
					<div><strong>3</strong><span>Next.js PWAs</span></div>
					<div><strong>3</strong><span>Laravel ERPs</span></div>
				</div>
			</div>
			<div class="portrait-wrap" data-parallax="0.035">
				<span class="portrait-index">01</span>
				<span class="orbit orbit-one"></span>
				<span class="orbit orbit-two"></span>
				<div class="portrait-frame">
					<img src="/profile.jpg" alt="Faisal Indrawan" width="2448" height="3264" fetchpriority="high" />
				</div>
				<p class="portrait-note">Based in Surabaya<br />Working across the stack</p>
			</div>
		</section>

		<div class="ticker" aria-hidden="true">
			<div>REACT NATIVE <span>+</span> NEXT.JS <span>+</span> LARAVEL <span>+</span> PRODUCT ENGINEERING <span>+</span> REACT NATIVE <span>+</span> NEXT.JS <span>+</span> LARAVEL <span>+</span> PRODUCT ENGINEERING <span>+</span></div>
		</div>

		<section id="about" class="section about">
			<p class="section-kicker">01 / About</p>
			<div class="about-grid">
				<h2>From interface polish to database logic, I care about the whole product.</h2>
				<div>
					<p>
						My work sits where engineering meets everyday operations: attendance,
						approvals, sales, logistics, booking, payments, and reporting. I enjoy
						understanding the real process first, then building the cleanest path through it.
					</p>
					<p>
						I collaborate closely with designers, QA, backend teams, and stakeholders—and
						stay involved through debugging, testing, deployment, and maintenance.
					</p>
				</div>
			</div>
		</section>

		<section id="experience" class="section">
			<div class="section-heading">
				<p class="section-kicker">02 / Experience</p>
				<h2>Selected work</h2>
			</div>
			<div class="timeline">
				{experience.map((job) => (
					<article class="job">
						<p class="period">{job.period}</p>
						<div class="job-title">
							<h3>{job.role}</h3>
							<p>{job.company}</p>
						</div>
						<div class="job-detail">
							<p class="job-copy">{job.copy}</p>
							{job.points.length > 0 && (
								<ul>
									{job.points.map((point) => <li>{point}</li>)}
								</ul>
							)}
						</div>
					</article>
				))}
			</div>
		</section>

		<section id="skills" class="section skills-section">
			<div class="section-heading">
				<p class="section-kicker">03 / Capabilities</p>
				<h2>Tools chosen for the problem—not the résumé.</h2>
			</div>
			<div class="skill-grid">
				{skills.map(([title, items, icon]) => (
					<article class="skill-card">
						<div class="skill-icon" aria-hidden="true">
							{icon === 'window' && (
								<svg viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="16" rx="2"/><path d="M3 9h18M7 6.5h.01M10 6.5h.01"/></svg>
							)}
							{icon === 'phone' && (
								<svg viewBox="0 0 24 24"><rect x="6" y="2" width="12" height="20" rx="2"/><path d="M10 5h4M11 18h2"/></svg>
							)}
							{icon === 'server' && (
								<svg viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="6" rx="2"/><rect x="3" y="14" width="18" height="6" rx="2"/><path d="M7 7h.01M7 17h.01M11 7h6M11 17h6"/></svg>
							)}
							{icon === 'database' && (
								<svg viewBox="0 0 24 24"><ellipse cx="12" cy="5" rx="8" ry="3"/><path d="M4 5v7c0 1.66 3.58 3 8 3s8-1.34 8-3V5M4 12v7c0 1.66 3.58 3 8 3s8-1.34 8-3v-7"/></svg>
							)}
						</div>
						<div>
							<h3>{title}</h3>
							<p>{items}</p>
						</div>
					</article>
				))}
			</div>
			<div class="education">
				<p class="section-kicker">Education</p>
				<div>
					<strong>Bachelor of Informatics Engineering</strong>
					<span>Artificial Intelligence concentration · Institut Teknologi Adhi Tama Surabaya · 2014—2020</span>
				</div>
			</div>
		</section>

		<section id="portfolio" class="section portfolio-section">
			<div class="section-heading">
				<p class="section-kicker">04 / Portfolio</p>
				<h2>Products built for work in the real world.</h2>
			</div>
			<div class="portfolio-groups">
				{portfolio.map((group) => (
					<div class="portfolio-group">
						<div class="portfolio-category">
							<h3>{group.category}</h3>
							<span>{String(group.projects.length).padStart(2, '0')} projects</span>
						</div>
						<div class="project-list">
							{group.projects.map(([name, description, links = [], status], index) => (
								<article class="project">
									<span class="project-number">{String(index + 1).padStart(2, '0')}</span>
									<div>
										<h4>{name}</h4>
										<p>{description}</p>
										{status && <span class="project-status">{status}</span>}
										{links.length > 0 && (
											<div class="project-links">
												{links.map(([label, url]) => (
													<a href={url} target="_blank" rel="noreferrer">{label} ↗</a>
												))}
											</div>
										)}
									</div>
								</article>
							))}
						</div>
					</div>
				))}
			</div>
		</section>

		<section id="contact" class="contact">
			<p class="section-kicker">05 / Contact</p>
			<h2>Have a useful problem to solve?</h2>
			<a class="contact-mail" href="mailto:isalindrawan@outlook.com">
				isalindrawan@outlook.com <span>↗</span>
			</a>
			<div class="contact-meta">
				<div class="social-links">
					{socialLinks.map(([label, url]) => (
						<a href={url} target="_blank" rel="noreferrer">{label} <span aria-hidden="true">↗</span></a>
					))}
				</div>
				<p>Surabaya, East Java · Indonesia</p>
			</div>
		</section>
	</main>

	<footer>
		<p>© {new Date().getFullYear()} Faisal Indrawan</p>
		<a href="#home">Back to top ↑</a>
	</footer>

	<script>
		const root = document.documentElement;
		const toggle = document.querySelector('.theme-toggle');
		const themeColor = document.querySelector('meta[name="theme-color"]');

		toggle?.addEventListener('click', () => {
			const theme = root.dataset.theme === 'dark' ? 'light' : 'dark';
			root.dataset.theme = theme;
			localStorage.setItem('theme', theme);
			themeColor?.setAttribute('content', theme === 'dark' ? '#131313' : '#f9f9f9');
		});

		if (!matchMedia('(prefers-reduced-motion: reduce)').matches) {
			const layers = document.querySelectorAll<HTMLElement>('[data-parallax]');
			const glow = document.querySelector<HTMLElement>('.cursor-glow');
			const revealItems = document.querySelectorAll<HTMLElement>(
				'.section-heading, .about-grid, .job, .skill-card, .education, .portfolio-group, .contact > *'
			);
			const observer = new IntersectionObserver((entries) => {
				entries.forEach((entry) => entry.isIntersecting && entry.target.classList.add('is-visible'));
			}, { threshold: .12 });
			revealItems.forEach((item) => {
				item.classList.add('reveal');
				observer.observe(item);
			});
			addEventListener('pointermove', (event) => {
				glow?.style.setProperty('--x', `${event.clientX}px`);
				glow?.style.setProperty('--y', `${event.clientY}px`);
			}, { passive: true });
			let ticking = false;
			const move = () => {
				layers.forEach((layer) => {
					const speed = Number(layer.dataset.parallax);
					layer.style.setProperty('--parallax-y', `${scrollY * speed}px`);
				});
				ticking = false;
			};
			addEventListener('scroll', () => {
				if (!ticking) requestAnimationFrame(move);
				ticking = true;
			}, { passive: true });
		}
	</script>
</Layout>

<style>
	.ambient {
		position: fixed;
		z-index: -1;
		border-radius: 50%;
		filter: blur(1px);
		pointer-events: none;
		transform: translate3d(0, var(--parallax-y, 0), 0);
		opacity: .52;
	}
	.ambient-one {
		width: 30rem; height: 30rem; top: 8rem; left: -18rem;
		background: radial-gradient(circle, var(--soft), transparent 68%);
	}
	.ambient-two {
		width: 24rem; height: 24rem; top: 58rem; right: -12rem;
		border: 1px solid var(--line);
	}
	.nav-shell {
		position: fixed;
		inset: 1rem 0 auto;
		z-index: 10;
		padding: 0 1rem;
	}
	nav {
		width: min(1120px, 100%);
		height: 4rem;
		margin: auto;
		padding: 0 .75rem 0 1.25rem;
		display: flex;
		align-items: center;
		justify-content: space-between;
		border: 1px solid var(--line);
		border-radius: 1rem;
		background: color-mix(in srgb, var(--paper) 70%, transparent);
		box-shadow: 0 8px 30px rgba(30, 29, 26, .08);
		backdrop-filter: blur(18px) saturate(130%);
	}
	.brand {
		font-size: 1.2rem;
		font-weight: 900;
		letter-spacing: -.08em;
		text-decoration: none;
	}
	.brand span { color: var(--soft); }
	.nav-links { display: flex; gap: clamp(1rem, 3vw, 2.5rem); }
	.nav-links a, footer a {
		color: var(--muted);
		font-size: .75rem;
		font-weight: 700;
		letter-spacing: .08em;
		text-decoration: none;
		text-transform: uppercase;
	}
	.nav-links a:hover, footer a:hover { color: var(--ink); }
	.theme-toggle {
		width: 2.75rem; height: 2.75rem;
		display: grid; place-items: center;
		color: var(--ink);
		border: 1px solid var(--line);
		border-radius: 50%;
		background: transparent;
		cursor: pointer;
	}
	.theme-toggle:hover { background: var(--panel); }
	.theme-toggle svg {
		position: absolute;
		width: 1.1rem;
		fill: none;
		stroke: currentColor;
		stroke-linecap: round;
		stroke-linejoin: round;
		stroke-width: 1.7;
		transition: opacity .2s, transform .25s;
	}
	.moon, :global([data-theme='dark']) .sun { opacity: 0; transform: rotate(-30deg) scale(.6); }
	.sun, :global([data-theme='dark']) .moon { opacity: 1; transform: rotate(0) scale(1); }
	main, footer { width: min(1120px, calc(100% - 2rem)); margin: auto; }
	.hero {
		min-height: 100svh;
		padding: 6.5rem 0 2rem;
		display: grid;
		grid-template-columns: 1.15fr .85fr;
		align-items: center;
		gap: clamp(2.5rem, 6vw, 6rem);
	}
	.eyebrow, .section-kicker {
		margin: 0 0 1.5rem;
		color: var(--muted);
		font-size: .72rem;
		font-weight: 800;
		letter-spacing: .14em;
		text-transform: uppercase;
	}
	h1, h2, h3, p { text-wrap: pretty; }
	h1 {
		max-width: 730px;
		margin: 0;
		font-size: clamp(3.6rem, 6.8vw, 6.4rem);
		line-height: .92;
		letter-spacing: -.075em;
	}
	h1 em { color: var(--soft); font-family: Georgia, serif; font-weight: 400; }
	.intro {
		max-width: 600px;
		margin: 1.5rem 0 0;
		color: var(--muted);
		font-size: clamp(1rem, 1.35vw, 1.15rem);
		line-height: 1.6;
	}
	.hero-actions { margin-top: 1.75rem; display: flex; align-items: center; gap: 1.5rem; }
	.button {
		padding: .95rem 1.2rem;
		display: inline-flex;
		gap: 2.5rem;
		color: var(--paper);
		background: var(--ink);
		border-radius: .35rem;
		font-size: .82rem;
		font-weight: 800;
		text-decoration: none;
	}
	.button:hover span { transform: translate(.15rem, .15rem); }
	.button span { transition: transform .2s; }
	.text-link {
		padding-bottom: .2rem;
		border-bottom: 1px solid var(--ink);
		font-size: .82rem;
		font-weight: 800;
		text-decoration: none;
	}
	.proof { margin-top: 2.5rem; display: flex; gap: clamp(1.5rem, 4vw, 3rem); }
	.proof div { display: grid; gap: .15rem; }
	.proof strong { font-size: 1.8rem; letter-spacing: -.05em; }
	.proof span { color: var(--muted); font-size: .72rem; }
	.portrait-wrap {
		position: relative;
		width: min(100%, 25rem);
		justify-self: end;
		transform: translate3d(0, var(--parallax-y, 0), 0);
	}
	.portrait-wrap::before {
		content: '';
		position: absolute;
		inset: 1.25rem -1.25rem -1.25rem 1.25rem;
		border: 1px solid var(--soft);
		border-radius: .4rem;
	}
	.portrait-frame {
		position: relative;
		aspect-ratio: 4 / 5;
		max-height: 68svh;
		overflow: hidden;
		border-radius: .4rem;
		box-shadow: var(--shadow);
		background: var(--accent);
	}
	.portrait-frame::after {
		content: '';
		position: absolute; inset: 0;
		box-shadow: inset 0 0 0 1px rgba(255,255,255,.18);
		border-radius: inherit;
	}
	.portrait-frame img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		object-position: 65% 40%;
		filter: contrast(1.04);
	}
	.portrait-note {
		position: absolute;
		left: -2rem; bottom: 2rem;
		margin: 0; padding: .8rem 1rem;
		color: var(--paper); background: var(--ink);
		font-size: .65rem; font-weight: 700; line-height: 1.6;
		letter-spacing: .08em; text-transform: uppercase;
	}
	.section { padding: clamp(6rem, 12vw, 10rem) 0; border-top: 1px solid var(--line); }
	.about-grid { display: grid; grid-template-columns: 1.15fr .85fr; gap: 8vw; }
	.about h2, .section-heading h2 {
		margin: 0;
		font-size: clamp(2.4rem, 5vw, 4.6rem);
		line-height: 1.06;
		letter-spacing: -.06em;
	}
	.about-grid > div { align-self: end; }
	.about-grid > div p {
		margin: 0 0 1.2rem;
		color: var(--muted);
		font-size: 1rem;
		line-height: 1.75;
	}
	.section-heading { margin-bottom: 4rem; display: grid; grid-template-columns: .55fr 1.45fr; }
	.section-heading .section-kicker { padding-top: .6rem; }
	.timeline { border-top: 1px solid var(--line); }
	#experience {
		isolation: isolate;
	}
	#experience::before {
		content: '';
		position: absolute;
		inset: 0 calc(50% - 50vw);
		z-index: -2;
		pointer-events: none;
		background:
			radial-gradient(circle at 10% 72%, color-mix(in srgb, var(--soft) 22%, transparent), transparent 27rem),
			repeating-linear-gradient(90deg, transparent 0 179px, var(--line) 180px 181px);
		-webkit-mask-image: linear-gradient(to bottom, transparent, rgba(0,0,0,.5) 24%, rgba(0,0,0,.5) 76%, transparent);
		mask-image: linear-gradient(to bottom, transparent, rgba(0,0,0,.5) 24%, rgba(0,0,0,.5) 76%, transparent);
	}
	.job {
		padding: 2.5rem 0;
		display: grid;
		grid-template-columns: .55fr .75fr 1.25fr;
		gap: 2rem;
		border-bottom: 1px solid var(--line);
	}
	.period { margin: .2rem 0 0; color: var(--muted); font-size: .75rem; font-weight: 700; }
