		.project-list { grid-template-columns: 1fr; }
		.project { min-height: auto; }
		.social-links { justify-content: flex-start; }
		.contact-meta { align-items: flex-start; flex-direction: column; gap: .8rem; }
	}

	/* Futuristic visual layer: native CSS keeps the effect fast and dependency-free. */
	:global(body)::before {
		content: '';
		position: fixed;
		inset: 0;
		z-index: 50;
		pointer-events: none;
		opacity: .055;
		background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 180 180' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='.9' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='.7'/%3E%3C/svg%3E");
	}
	:global(body)::after {
		content: '';
		position: fixed;
		inset: 0;
		z-index: -3;
		pointer-events: none;
		background:
			radial-gradient(circle at 12% 8%, color-mix(in srgb, var(--soft) 22%, transparent), transparent 24rem),
			radial-gradient(circle at 88% 38%, color-mix(in srgb, var(--soft) 15%, transparent), transparent 30rem);
	}
	.cursor-glow {
		position: fixed;
		left: 0;
		top: 0;
		z-index: -1;
		width: 34rem;
		aspect-ratio: 1;
		border-radius: 50%;
		pointer-events: none;
		background: radial-gradient(circle, color-mix(in srgb, var(--soft) 14%, transparent), transparent 65%);
		transform: translate(calc(var(--x, 50vw) - 50%), calc(var(--y, 50vh) - 50%));
		transition: transform .12s linear;
	}
	.ambient { border-radius: 0; opacity: .85; }
	.ambient-one {
		width: 36rem;
		height: 36rem;
		top: -14rem;
		left: -15rem;
		background: transparent;
		border: 1px solid var(--soft);
		transform: translate3d(0, var(--parallax-y, 0), 0) rotate(32deg);
		animation: ambient-spin 28s linear infinite;
	}
	.ambient-two {
		width: 32rem;
		height: 32rem;
		top: 74rem;
		right: -18rem;
		border: 7rem solid color-mix(in srgb, var(--soft) 9%, transparent);
		transform: translate3d(0, var(--parallax-y, 0), 0) rotate(45deg);
	}
	.ambient-three {
		width: 15rem;
		height: 42rem;
		top: 180rem;
		left: 4vw;
		border: 1px solid var(--line);
		background: repeating-linear-gradient(135deg, transparent 0 12px, var(--line) 13px 14px);
		transform: translate3d(0, var(--parallax-y, 0), 0) rotate(18deg);
	}
	@keyframes ambient-spin { to { rotate: 360deg; } }

	.nav-shell { inset: .8rem 0 auto; }
	nav {
