---
// Terminal-themed floating code snippets. Vanilla canvas, no deps.
// Lines of pseudo-code drift upward at very low opacity behind content.
// Respects prefers-reduced-motion (static frame).
---
<canvas id="particles" class="fixed inset-0 z-0 pointer-events-none" aria-hidden="true"></canvas>
<script is:inline>
  (function () {
    var canvas = document.getElementById('particles');
    if (!canvas) return;
    var ctx = canvas.getContext('2d');
    if (!ctx) return;
    var reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    var dpr = Math.min(window.devicePixelRatio || 1, 2);
    var w = 0, h = 0;

    var SNIPPETS = [
      'const app = await build()',
      'pnpm build --verbose',
      'export default function Hero() {}',
      'if (shipped) return celebrate()',
      'git commit -m "ship it"',
      'async function deploy() { ... }',
      '> whoami',
      'return { ok: true, data }',
      'const [lang, setLang] = useState()',
      'npm run dev --host',
      '// TODO: make it delightful',
      'try { await release() } catch (e) {}',
      'interface Profile { name: string }',
      'const user = await fetch(url)',
      'class Developer extends Human {}',
      'while (curious) keepLearning()',
      'export const stack = ["react", "laravel"]',
      'docker compose up -d',
      'SELECT * FROM experiences;',
      'pnpm install --frozen-lockfile',
      'function ship(feature) { return done }',
      'import Layout from "./Layout.astro"',
      'const result = array.map(x => x.id)',
      'curl https://isalindrawan.netlify.app',
      '// ponies: simplest path to done',
      'git push origin main'
    ];

    var lines = [];
    var accent = '#00ff9c';
    var muted = '#5c6773';
    var fontSize = 13;

    function readTheme() {
      try {
        var cs = getComputedStyle(document.documentElement);
        var a = cs.getPropertyValue('--accent').trim();
        var m = cs.getPropertyValue('--muted').trim();
        if (a) accent = a;
        if (m) muted = m;
      } catch (e) {}
    }

    function size() {
      w = window.innerWidth;
      h = window.innerHeight;
      canvas.width = w * dpr;
      canvas.height = h * dpr;
      canvas.style.width = w + 'px';
      canvas.style.height = h + 'px';
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
      ctx.font = fontSize + "px 'JetBrains Mono', ui-monospace, monospace";
      ctx.textBaseline = 'top';
    }

    function rand(a, b) { return a + Math.random() * (b - a); }

    function spawn(initial) {
      return {
        text: SNIPPETS[Math.floor(Math.random() * SNIPPETS.length)],
        x: rand(0, Math.max(1, w - 320)),
        y: initial ? rand(0, h) : h + rand(20, 120),
        speed: rand(0.12, 0.38),
        alpha: rand(0.05, 0.13),
        tint: Math.random() < 0.18 ? 'accent' : 'muted'
      };
    }

    function seed() {
      var n = Math.max(10, Math.min(20, Math.floor(w / 90)));
      lines = [];
      for (var i = 0; i < n; i++) lines.push(spawn(true));
    }

    function draw() {
      ctx.clearRect(0, 0, w, h);
      for (var i = 0; i < lines.length; i++) {
        var l = lines[i];
        ctx.globalAlpha = l.alpha;
        ctx.fillStyle = l.tint === 'accent' ? accent : muted;
        ctx.fillText(l.text, l.x, l.y);
      }
      ctx.globalAlpha = 1;
    }

    function step() {
      for (var i = 0; i < lines.length; i++) {
        var l = lines[i];
        l.y -= l.speed;
        if (l.y < -20) {
          lines[i] = spawn(false);
        }
      }
      draw();
      raf = requestAnimationFrame(step);
    }

    var raf = null;
    function start() {
      if (raf) cancelAnimationFrame(raf);
      if (reduce) { draw(); return; }
      step();
    }

    var resizeTimer;
    function onResize() {
      clearTimeout(resizeTimer);
      resizeTimer = setTimeout(function () {
        readTheme();
        size();
        seed();
        start();
      }, 150);
    }

    function init() {
      readTheme();
      size();
      seed();
      start();
      window.addEventListener('resize', onResize, { passive: true });
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', init);
    } else {
      init();
    }
  })();
</script>
