---
import { Icon } from 'astro-icon/components';
interface Props { t: { toggle: string; dark: string; light: string } }
const { t } = Astro.props;
---
<button
  id="theme-toggle"
  type="button"
  class="h-8 w-8 grid place-items-center rounded border border-[var(--border)] hover:border-[var(--accent)] text-[var(--muted)] hover:text-[var(--accent)] transition-colors"
  aria-label={t.toggle}
  title={t.toggle}
>
  <Icon name="lucide:moon" class="dark:hidden" size={16} />
  <Icon name="lucide:sun" class="hidden dark:block" size={16} />
</button>
<script is:inline>
  (function () {
    const btn = document.getElementById('theme-toggle');
    if (!btn) return;
    btn.addEventListener('click', () => {
      const el = document.documentElement;
      const next = el.classList.contains('dark') ? 'light' : 'dark';
      el.classList.remove('dark', 'light');
      el.classList.add(next);
      try { localStorage.setItem('theme', next); } catch (e) {}
    });
  })();
</script>
