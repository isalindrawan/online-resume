---
interface Props {
  id: string;
  prompt: string;
  title: string;
  /** hash after the prompt, e.g. section name */
  arg?: string;
}
const { id, prompt, title, arg = '' } = Astro.props;
---
<section id={id} class="relative py-20 px-4">
  <!-- parallax background glyph layer -->
  <div
    data-parallax
    data-parallax-speed="-0.06"
    aria-hidden="true"
    class="pointer-events-none absolute inset-0 overflow-hidden select-none"
  >
    <span class="absolute -left-2 top-8 text-[10rem] leading-none font-bold text-[var(--accent)] opacity-[0.04]">#{arg || id}</span>
  </div>

  <div class="relative max-w-5xl mx-auto" data-reveal>
    <div class="flex items-center gap-2 text-sm mb-2 flex-wrap">
      <span class="prompt">{prompt}</span>
      {arg && <span class="muted">{arg}</span>}
    </div>
    <h2 class="text-2xl sm:text-3xl font-bold mb-8">
      <span class="accent-text">#</span>{title}
    </h2>
    <slot />
  </div>
</section>
