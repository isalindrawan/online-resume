---
import type { Experience } from '../data/types';
import SkillChip from './SkillChip.astro';

interface Props {
  item: Experience;
  index: number;
  t: { stack: string };
}
const { item, index, t } = Astro.props;
---
<article data-reveal class="card p-5 hover:border-[var(--accent)] transition-colors">
  <div class="flex items-start justify-between gap-4 flex-wrap">
    <div>
      <div class="text-xs muted">
        <span class="accent-text">{String(index + 1).padStart(2, '0')}</span>
        <span class="mx-1">·</span>
        <span>{item.period}</span>
      </div>
      <h3 class="text-lg font-bold mt-1">{item.role}</h3>
      <p class="text-sm text-[var(--cyan)]">
        {item.company}
        <span class="muted mx-1">·</span>
        <span class="muted">{item.location}</span>
      </p>
    </div>
  </div>

  <ul class="mt-4 space-y-2 text-sm leading-relaxed">
    {item.highlights.map((h) => (
      <li class="flex gap-2">
        <span class="accent-text mt-0.5 select-none">›</span>
        <span>{h}</span>
      </li>
    ))}
  </ul>

  <div class="mt-4 pt-3 border-t border-[var(--border)]">
    <div class="text-[10px] uppercase tracking-wider muted mb-2">{t.stack}</div>
    <div class="flex flex-wrap gap-2">
      {item.stack.map((s) => (
        <SkillChip name={s} icon="lucide:code" />
      ))}
    </div>
  </div>
</article>
