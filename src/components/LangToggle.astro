---
import type { Lang } from '../data/types';
interface Props { lang: Lang }
const { lang } = Astro.props;
const target: Lang = lang === 'id' ? 'en' : 'id';
const href = `/${target}`;
const label = lang === 'id' ? 'EN' : 'ID';
const title = lang === 'id' ? 'View in English' : 'Lihat dalam Bahasa Indonesia';
const aria = lang === 'id' ? 'Switch language to English' : 'Ganti bahasa ke Bahasa Indonesia';
---
<a
  href={href}
  class="h-8 px-2 grid place-items-center rounded border border-[var(--border)] hover:border-[var(--accent)] text-[var(--muted)] hover:text-[var(--accent)] transition-colors text-xs font-bold"
  title={title}
  aria-label={aria}
>{label}</a>
