---
import { Icon } from 'astro-icon/components';
import type { Social, Lang } from '../data/types';
import SocialButton from './SocialButton.astro';
interface Props {
  lang: Lang;
  socials: Social[];
  t: { builtWith: string; back: string; socials: string };
}
const { lang, socials, t } = Astro.props;
---
<footer class="relative border-t border-[var(--border)] mt-10 px-4 py-10">
  <div class="max-w-5xl mx-auto flex flex-col sm:flex-row items-center justify-between gap-4">
    <SocialButton socials={socials} t={{ socials: t.socials }} />
    <p class="muted text-xs">// {t.builtWith}</p>
    <a href={`/${lang}#main`} class="muted text-xs hover:text-[var(--accent)] transition-colors inline-flex items-center gap-1">
      <Icon name="lucide:arrow-up" size={13} />
      {t.back}
    </a>
  </div>
</footer>
